<div class="metric-card" style="
    background: var(--color-bg-secondary);
    border-radius: var(--radius-md);
    padding: 16px;
    border-left: 4px solid
    {% if isCritical %}var(--color-critical)
    {% elseif isWarning %}var(--color-warn)
    {% else %}var(--color-brand){% endif %};
">
    <div style="display: flex; align-items: center; gap: 12px;">
        {% if icon %}
        <div style="font-size: 20px; color:
            {% if isCritical %}var(--color-critical)
            {% elseif isWarning %}var(--color-warn)
            {% else %}var(--color-brand){% endif %};">
            <i class="{{ icon }}"></i>
        </div>
        {% endif %}
        <div>
            <div style="font-size: 12px; color: var(--color-text-secondary);">{{ label }}</div>
            <div style="font-size: 18px; font-weight: 600; color: var(--color-text-primary);">
                {{ value is not null ? value|number_format(2) : '—' }} {{ unit }}
            </div>
        </div>
    </div>
</div>
