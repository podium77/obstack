{
    "name": "obstack/platform-v2",
    "description": "Plateforme d'observabilité multi-tenant avec Kubernetes, PyRCA et Knowledge Graph",
    "type": "project",
    "license": "proprietary",

    "minimum-stability": "stable",
    "prefer-stable": true,

    "require": {
        "php": ">=8.4",
        "ext-bcmath": "*",
        "ext-curl": "*",
        "ext-intl": "*",
        "ext-json": "*",
        "ext-ldap": "*",
        "ext-mbstring": "*",
        "ext-pdo": "*",
        "ext-redis": "*",
        "ext-ssh2": "*",
        "ext-xml": "*",
        "ext-zip": "*",
        "doctrine/annotations": "^2.0",
        "doctrine/doctrine-bundle": "^3.2",
        "doctrine/doctrine-migrations-bundle": "^4.0",
        "doctrine/orm": "^3.6",
        "firebase/php-jwt": "^7.1",
        "predis/predis": "^2.2",
        "symfony/asset": "^7.4",
        "symfony/asset-mapper": "^7.4",
        "symfony/cache": "^7.4",
        "symfony/console": "^7.4",
        "symfony/dotenv": "^8.0",
        "symfony/flex": "^2.8",
        "symfony/form": "^7.4",
        "symfony/framework-bundle": "^7.4",
        "symfony/http-client": "^7.4",
        "symfony/ldap": "^7.4",
        "symfony/mailer": "^7.4",
        "symfony/messenger": "^7.4",
        "symfony/password-hasher": "^7.4",
        "symfony/process": "^7.4",
        "symfony/rate-limiter": "^7.4",
        "symfony/runtime": "^7.4",
        "symfony/scheduler": "^7.4",
        "symfony/security-bundle": "^7.4",
        "symfony/serializer": "^7.4",
        "symfony/translation": "^7.4",
        "symfony/twig-bundle": "^7.4",
        "symfony/ux-chartjs": "^2.20",
        "symfony/ux-live-component": "^2.20",
        "symfony/ux-turbo": "^2.20",
        "symfony/validator": "^7.4",
        "symfony/yaml": "^7.4",
        "twig/extra-bundle": "^3.10",
        "twig/twig": "^3.10"
    },

    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "symfony/browser-kit": "^8.0",
        "symfony/css-selector": "^8.0",
        "symfony/debug-bundle": "^7.4",
        "symfony/maker-bundle": "^1.64",
        "symfony/stopwatch": "^8.0",
        "symfony/web-profiler-bundle": "^7.4"
    },

    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },

    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },

    "scripts": {
        "auto-scripts": {
            "assets:install %PUBLIC_DIR%": "symfony-cmd",
            "importmap:install": "symfony-cmd"
        },

        "post-install-cmd": [
            "@auto-scripts"
        ],

        "post-update-cmd": [
            "@auto-scripts"
        ]
    },

    "extra": {
        "symfony": {
            "allow-contrib": true
        }
    },

    "config": {
        "optimize-autoloader": true,

        "preferred-install": {
            "*": "dist"
        },

        "sort-packages": true,

        "allow-plugins": {
            "composer/package-versions-deprecated": true,
            "php-http/discovery": true,
            "symfony/flex": true,
            "symfony/runtime": true
        },

        "audit": {
            "block-insecure": false
        }
    }
}
