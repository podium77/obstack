{% extends 'base.html.twig' %}

{% block title %}Paramètres RCA{% endblock %}
{% block page_title %}Paramètres RCA{% endblock %}

{% block content %}
<form method="post">
    <div style="background:var(--color-bg-primary);border:1px solid var(--color-border);border-radius:var(--radius-md);padding:28px">
        <div style="margin-bottom:20px">
            <h3 style="font-size:15px;font-weight:600;margin-bottom:8px">Activation</h3>
            <div class="form-group">
                <label style="display:flex;align-items:center;gap:8px;cursor:pointer">
                    <input type="checkbox" name="rca_enabled" {{ company.isRcaEnabled ? 'checked' }} style="width:16px;height:16px;accent-color:var(--color-brand)">
                    <span class="form-label" style="margin:0">Activer RCA pour cette entreprise</span>
                </label>
                <div class="form-hint">
                    Activez cette option pour permettre les analyses de cause racine automatiques.
                </div>
            </div>
        </div>

        <div style="margin-bottom:20px">
            <h3 style="font-size:15px;font-weight:600;margin-bottom:8px">Configuration de l'API RCA</h3>
            <div class="grid-2">
                <div class="form-group">
                    <label class="form-label">URL de l'API RCA *</label>
                    <input type="url" name="rca_api_url" value="{{ company.rcaConfig.api_url ?? '' }}" placeholder="https://rca.example.com/api" required>
                </div>
                <div class="form-group">
                    <label class="form-label">Clé API *</label>
                    <input type="password" name="rca_api_key" value="{{ company.rcaConfig.api_key ?? '' }}" placeholder="Votre clé API RCA" required>
                </div>
            </div>
            <div class="grid-2">
                <div class="form-group">
                    <label class="form-label">Modèle d'analyse</label>
                    <select name="rca_model">
                        <option value="bayesian" {{ (company.rcaConfig.model ?? 'bayesian') == 'bayesian' ? 'selected' }}>Bayésien</option>
                        <option value="ml" {{ (company.rcaConfig.model ?? '') == 'ml' ? 'selected' }}>Machine Learning</option>
                        <option value="rule_based" {{ (company.rcaConfig.model ?? '') == 'rule_based' ? 'selected' }}>Basé sur des règles</option>
                    </select>
                </div>
                <div class="form-group">
                    <label style="display:flex;align-items:center;gap:8px;cursor:pointer">
                        <input type="checkbox" name="rca_auto_analyze" {{ company.rcaConfig.auto_analyze ?? false ? 'checked' }} style="width:16px;height:16px;accent-color:var(--color-brand)">
                        <span class="form-label" style="margin:0">Analyse automatique</span>
                    </label>
                    <div class="form-hint">Lancer automatiquement une analyse RCA pour chaque nouvelle alerte critique.</div>
                </div>
            </div>
        </div>
    </div>

    <div style="display:flex;justify-content:end;margin-top:20px">
        <button type="submit" class="btn btn-primary">
            <i class="ti ti-check"></i> Enregistrer
        </button>
    </div>
</form>
{% endblock %}
