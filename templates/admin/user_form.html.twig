{% extends 'base.html.twig' %}
{% block title %}{{ isNew ? 'Nouvel utilisateur' : 'Modifier ' ~ user.username }}{% endblock %}
{% block page_title %}{{ isNew ? 'Nouvel utilisateur' : 'Modifier l\'utilisateur' }}{% endblock %}
{% block page_subtitle_content %}{{ company ? company.name : 'Global' }}{% endblock %}

{% block content %}
<div style="max-width:700px">
<form method="post">
<div class="card mb-4">
    <div class="card-header"><div class="card-header-title"><i class="ti ti-user"></i>Informations du compte</div></div>
    <div class="card-body">

        {# Superadmin: champs limités #}
        {% if not isNew and user.isSuperAdmin %}
        <div style="background:var(--color-warn-light);border-radius:var(--radius-sm);padding:10px 14px;margin-bottom:16px;font-size:12.5px;color:#92400e">
            <i class="ti ti-crown"></i> Compte Superadmin — seuls l'email, le nom et le mot de passe sont modifiables.
        </div>
        {% endif %}

        <div class="grid-2">
            <div class="form-group">
                <label class="form-label">Identifiant *</label>
                <input type="text" name="username" value="{{ user.username }}"
                       {{ not isNew ? 'readonly style=background:#f8f9fb' : 'required placeholder=jdupont' }}>
            </div>
            <div class="form-group">
                <label class="form-label">Nom complet</label>
                <input type="text" name="display_name" value="{{ user.displayName }}" placeholder="Jean Dupont">
            </div>
        </div>

        <div class="form-group">
            <label class="form-label">Email</label>
            <input type="email" name="email" value="{{ user.email }}" placeholder="jean.dupont@company.local">
        </div>

        <div class="form-group">
            <label class="form-label">Mot de passe {{ isNew ? '*' : '(laisser vide = inchangé)' }}</label>
            <input type="password" name="password" {{ isNew and user.type == 'local' ? 'required' : '' }}
                   autocomplete="new-password" placeholder="••••••••">
            <div class="form-hint">Minimum 8 caractères. Non requis pour les comptes LDAP.</div>
        </div>

        {% if not user.isSuperAdmin %}
        <div class="grid-2">
            <div class="form-group">
                <label class="form-label">Type de compte</label>
                <select name="type" id="user-type" onchange="toggleLdapFields(this.value)">
                    <option value="local" {{ user.type == 'local' ? 'selected' }}>Local (compte interne)</option>
                    <option value="ldap"  {{ user.type == 'ldap'  ? 'selected' }}>LDAP (annuaire entreprise)</option>
                </select>
                <div class="form-hint">
                    Rappel: max 1 compte local par environnement (hors superadmin).
                </div>
            </div>
            <div class="form-group">
                <label class="form-label">Compte actif</label>
                <div style="margin-top:9px">
                    <label style="display:flex;align-items:center;gap:8px;cursor:pointer">
                        <input type="checkbox" name="active" {{ user.isActive ? 'checked' }}
                               style="width:16px;height:16px;accent-color:var(--color-brand)">
                        <span style="font-size:13px">Autoriser la connexion</span>
                    </label>
                </div>
            </div>
        </div>

        <div id="ldap-fields" style="{{ user.isLdap ? '' : 'display:none' }}">
            <div class="form-group">
                <label class="form-label">DN LDAP</label>
                <input type="text" name="ldap_dn" value="{{ user.ldapDn }}"
                       placeholder="cn=jean.dupont,ou=users,dc=company,dc=local" class="font-mono">
                <div class="form-hint">Laissez vide pour auto-détection lors de la première connexion LDAP.</div>
            </div>
        </div>

        <div class="form-group">
            <label style="display:flex;align-items:center;gap:8px;cursor:pointer">
                <input type="checkbox" name="global_access" {{ user.hasGlobalAccess ? 'checked' }}
                       style="width:16px;height:16px;accent-color:var(--color-brand)">
                <div>
                    <span style="font-size:13px;font-weight:500">Accès global à tous les environnements</span>
                    <div class="form-hint">Accorde l'accès en lecture à tous les envs sans configuration individuelle.</div>
                </div>
            </label>
        </div>
        {% endif %}

    </div>
</div>

{# Droits par environnement #}
{% if not user.isSuperAdmin and envs %}
<div class="card mb-4">
    <div class="card-header"><div class="card-header-title"><i class="ti ti-shield-check"></i>Droits par environnement</div></div>
    <div class="card-body">
        <div style="font-size:12.5px;color:var(--color-text-secondary);margin-bottom:14px">
            Assignez un rôle spécifique à cet utilisateur pour chaque environnement. Laissez "Aucun accès" pour exclure l'utilisateur.
        </div>
        <div style="display:grid;gap:10px">
        {% for env in envs %}
        <div style="display:flex;align-items:center;gap:12px;padding:10px 14px;background:var(--color-bg-secondary);border-radius:var(--radius-md)">
            <span style="width:10px;height:10px;border-radius:50%;background:{{ env.color }};flex-shrink:0"></span>
            <div style="flex:1">
                <div style="font-weight:500;font-size:13px">{{ env.name }}</div>
                <div class="text-muted text-sm">{{ env.type.getLabel() }}</div>
            </div>
            <select name="env_roles[{{ env.id }}]" style="width:180px;padding:6px 10px;border:1px solid var(--color-border);border-radius:6px;font-size:12.5px">
                <option value="">— Aucun accès —</option>
                {% for role in roles %}
                <option value="{{ role.value }}" {{ (currentAccess[env.id] ?? '') == role.value ? 'selected' }}>
                    {{ role.getLabel() }}
                </option>
                {% endfor %}
            </select>
        </div>
        {% endfor %}
        </div>
    </div>
</div>
{% endif %}

<div style="display:flex;justify-content:space-between;align-items:center">
    <div style="display:flex;gap:8px">
        <a href="{{ path('admin_users') }}" class="btn btn-secondary"><i class="ti ti-arrow-left"></i>Annuler</a>
        {% if not isNew and not user.isSuperAdmin %}
        <button type="button" onclick="deleteUser({{ user.id }})" class="btn btn-danger">
            <i class="ti ti-trash"></i>Supprimer
        </button>
        {% endif %}
    </div>
    <button type="submit" class="btn btn-primary">
        <i class="ti ti-check"></i>{{ isNew ? 'Créer le compte' : 'Enregistrer' }}
    </button>
</div>
<input type="hidden" name="_csrf_token" id="csrf-token" value="">
</form>
</div>
{% endblock %}

{% block javascript %}
<script>
function toggleLdapFields(type) {
    const ldapFields = document.getElementById('ldap-fields');

    if (ldapFields) {
        ldapFields.style.display = type === 'ldap' ? 'block' : 'none';
    }
}

{% if not isNew and user.id %}
async function deleteUser(userId) {
    if (!confirm('Supprimer cet utilisateur ? Cette action est irréversible.')) {
        return;
    }

    const token = '{{ csrf_token("delete_user_" ~ user.id) }}';
    const res = await fetch('{{ path("admin_user_delete", {id: user.id}) }}', {
        method: 'POST',
        body: new URLSearchParams({
            '_token': token
        }),
        headers: {
            'Content-Type': 'application/x-www-form-urlencoded'
        }
    });

    const data = await res.json();
    if (data.success) {
        location.href = '{{ path("admin_users") }}';
    }
}
{% endif %}
</script>
{% endblock %}
