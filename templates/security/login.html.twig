<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Connexion — obstack</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@3.0.0/dist/tabler-icons.min.css">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            font-family: system-ui, -apple-system, sans-serif;
            background: linear-gradient(135deg, #0a1628 0%, #0f2744 50%, #185FA5 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 16px;
        }
        .login-wrap { width: 100%; max-width: 420px; }
        .login-card {
            background: #fff;
            border-radius: 18px;
            padding: 40px 36px;
            box-shadow: 0 24px 80px rgba(0,0,0,.3);
        }
        .logo-row {
            display: flex; align-items: center; justify-content: center;
            gap: 12px; margin-bottom: 28px;
        }
        .logo-icon {
            width: 46px; height: 46px; background: #185FA5; border-radius: 11px;
            display: flex; align-items: center; justify-content: center;
            color: #fff; font-size: 23px;
        }
        .logo-text h1 { font-size: 21px; font-weight: 700; color: #1a1d23; }
        .logo-text p  { font-size: 12px; color: #6b7280; }
        .company-chip {
            display: flex; align-items: center; gap: 8px;
            background: #eff6ff; border: 1.5px solid #bfdbfe; border-radius: 9px;
            padding: 10px 14px; margin-bottom: 20px; cursor: pointer;
        }
        .company-chip .icon { font-size: 20px; color: #185FA5; }
        .company-chip .name { font-size: 13.5px; font-weight: 600; color: #185FA5; flex: 1; }
        .company-chip .change { font-size: 11px; color: #185FA5; text-decoration: underline; }
        .company-input-row {
            margin-bottom: 20px;
            display: none;
        }
        .company-input-row.visible { display: block; }
        .form-group { margin-bottom: 16px; }
        label { display: block; font-size: 12.5px; font-weight: 500; color: #374151; margin-bottom: 5px; }
        .input-wrap { position: relative; }
        .input-icon { position: absolute; left: 12px; top: 50%; transform: translateY(-50%); color: #9ca3af; font-size: 17px; pointer-events: none; }
        input[type="text"], input[type="password"] {
            width: 100%; padding: 10px 12px 10px 38px;
            border: 1.5px solid #e2e6ea; border-radius: 8px;
            font-size: 14px; color: #1a1d23; background: #f9fafb;
            transition: all .15s;
        }
        input:focus { outline: none; border-color: #185FA5; background: #fff; box-shadow: 0 0 0 3px rgba(24,95,165,.1); }
        .remember-row { display: flex; align-items: center; gap: 8px; margin-bottom: 20px; }
        .remember-row input[type="checkbox"] { width: 16px; height: 16px; accent-color: #185FA5; cursor: pointer; }
        .remember-row label { margin: 0; font-size: 13px; color: #6b7280; cursor: pointer; }
        .btn-login {
            width: 100%; padding: 12px; background: #185FA5; color: #fff;
            border: none; border-radius: 8px; font-size: 14.5px; font-weight: 600;
            cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 8px;
            transition: background .15s;
        }
        .btn-login:hover { background: #0f4578; }
        .alert-error {
            background: #fee2e2; color: #b91c1c; border: 1px solid #fca5a5;
            border-radius: 8px; padding: 10px 14px; font-size: 13px;
            margin-bottom: 16px; display: flex; align-items: center; gap: 8px;
        }
        .ldap-badge {
            display: inline-flex; align-items: center; gap: 5px;
            background: #f0fdf4; border: 1px solid #bbf7d0; border-radius: 6px;
            padding: 4px 10px; font-size: 11.5px; color: #15803d; margin-bottom: 16px;
        }
        .divider { text-align: center; color: #9ca3af; font-size: 12px; margin: 20px 0; position: relative; }
        .divider::before, .divider::after { content: ''; position: absolute; top: 50%; width: 44%; height: 1px; background: #e2e6ea; }
        .divider::before { left: 0; } .divider::after { right: 0; }
        .register-link {
            text-align: center; margin-top: 20px; padding-top: 16px;
            border-top: 1px solid #f0f2f5; font-size: 13px; color: #6b7280;
        }
        .register-link a { color: #185FA5; text-decoration: none; font-weight: 500; }
        /* Bubbles background */
        .bg-circles { position: fixed; inset: 0; pointer-events: none; z-index: 0; overflow: hidden; }
        .circle { position: absolute; border-radius: 50%; background: rgba(255,255,255,.04); }
        .login-wrap { position: relative; z-index: 1; }
    </style>
</head>
<body>
<div class="bg-circles">
    <div class="circle" style="width:500px;height:500px;top:-200px;right:-150px"></div>
    <div class="circle" style="width:350px;height:350px;bottom:-100px;left:-80px"></div>
    <div class="circle" style="width:200px;height:200px;top:35%;left:8%"></div>
</div>

<div class="login-wrap">
<div class="login-card">

    <div class="logo-row">
        <img src="{{ asset('images/brand/icons/logo-icon_black-color.png') }}" alt ="" width="46" height="46">
        <div class="logo-text">
            <h1>obstack</h1>
            <p>Plateforme d'observabilité multi-stacks</p>
        </div>
    </div>

    {% if error %}
    <div class="alert-error">
        <i class="ti ti-alert-circle"></i>
        {{ error.messageKey|trans(error.messageData, 'security') }}
    </div>
    {% endif %}

    {# Affichage de l'entreprise détectée en session #}
    {% set savedSlug = app.session.get('company_slug') %}
    {% if savedSlug %}
    <div class="company-chip" id="company-chip" onclick="changeCompany()">
        <i class="ti ti-building icon"></i>
        <span class="name" id="company-name-display">Entreprise: {{ savedSlug }}</span>
        <span class="change">Changer</span>
    </div>
    {% endif %}

    <form method="post" action="{{ path('app_login') }}" id="login-form">

        {# Champ identifiant entreprise #}
        <div class="company-input-row {{ not savedSlug ? 'visible' : '' }}" id="company-input-row">
            <div class="form-group">
                <label>Identifiant de votre entreprise</label>
                <div class="input-wrap">
                    <i class="ti ti-building input-icon"></i>
                    <input type="text" name="company_slug" id="company-slug-input"
                           value="{{ savedSlug ?? '' }}"
                           placeholder="mon-entreprise-a3f8b2"
                           autocomplete="organization"
                           oninput="detectCompany(this.value)">
                </div>
                <div style="font-size:11.5px;color:#9ca3af;margin-top:3px" id="company-detect-msg"></div>
            </div>
        </div>
        <input type="hidden" name="company_slug" id="company-slug-hidden" value="{{ savedSlug ?? '' }}">

        <div class="form-group">
            <label>Identifiant</label>
            <div class="input-wrap">
                <i class="ti ti-user input-icon"></i>
                <input type="text" name="username" value="{{ last_username }}"
                       autocomplete="username" placeholder="votre.identifiant" required>
            </div>
        </div>

        <div class="form-group">
            <label>Mot de passe</label>
            <div class="input-wrap">
                <i class="ti ti-lock input-icon"></i>
                <input type="password" name="password" autocomplete="current-password" placeholder="••••••••••" required>
            </div>
        </div>

        <div class="remember-row">
            <input type="checkbox" id="remember" name="_remember_me">
            <label for="remember">Se souvenir de moi (7 jours)</label>
        </div>

        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

        <button type="submit" class="btn-login">
            <i class="ti ti-login"></i>Se connecter
        </button>
    </form>

    <div id="ldap-indicator" style="display:none;margin-top:12px">
        <span class="ldap-badge"><i class="ti ti-server-2"></i>Authentification LDAP disponible</span>
    </div>

    <div class="register-link">
        Nouvelle entreprise ? <a href="{{ path('register_index') }}">Créer une instance obstack</a>
    </div>

</div>
</div>

<script>
let companyDetectTimeout;

function changeCompany() {
    document.getElementById('company-chip')?.remove();
    const row = document.getElementById('company-input-row');
    row.classList.add('visible');
    document.getElementById('company-slug-input').focus();
}

function detectCompany(val) {
    // Synchroniser le champ caché
    document.getElementById('company-slug-hidden').value = val;

    clearTimeout(companyDetectTimeout);
    const msg = document.getElementById('company-detect-msg');
    if (!val || val.length < 3) { msg.textContent = ''; return; }

    companyDetectTimeout = setTimeout(async () => {
        msg.textContent = 'Recherche…';
        try {
            const res  = await fetch('/api/company/detect?slug=' + encodeURIComponent(val));
            const data = await res.json();
            if (data.found) {
                msg.innerHTML = `<span style="color:#15803d">✓ ${data.name}</span>`;
                document.getElementById('ldap-indicator').style.display = data.has_ldap ? 'block' : 'none';
            } else {
                msg.innerHTML = '<span style="color:#b91c1c">Entreprise introuvable</span>';
            }
        } catch { msg.textContent = ''; }
    }, 600);
}

// Si le slug est déjà renseigné, synchroniser le champ caché
const slugInput = document.getElementById('company-slug-input');
if (slugInput && slugInput.value) {
    document.getElementById('company-slug-hidden').value = slugInput.value;
}
</script>
</body>
</html>
