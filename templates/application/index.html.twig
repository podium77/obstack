{% extends 'base.html.twig' %}
{% block title %}Applications{% endblock %}
{% block page_title %}Applications supervisées{% endblock %}
{% block page_subtitle_content %}{{ apps|length }} application(s) dans {{ obs_envs|length }} environnement(s){% endblock %}

{% block topbar_actions %}
{% if is_granted('ROLE_SUPERADMIN') %}
<a href="{{ path('app_application_new') }}" class="btn btn-primary">
    <i class="ti ti-plus"></i>Ajouter une application
</a>
{% endif %}
{% endblock %}

{% block content %}

{# Filtres #}
<div style="display:flex;gap:8px;margin-bottom:16px;flex-wrap:wrap;align-items:center">
    <span style="font-size:12.5px;color:var(--color-text-secondary)">Filtrer par:</span>
    <select id="filter-env" onchange="filterApps()" style="padding:6px 10px;border:1px solid var(--color-border);border-radius:6px;font-size:13px">
        <option value="">Tous les environnements</option>
        {% for env in obs_envs %}
        <option value="{{ env.id }}">{{ env.name }} ({{ env.type.getLabel() }})</option>
        {% endfor %}
    </select>
    <select id="filter-status" onchange="filterApps()" style="padding:6px 10px;border:1px solid var(--color-border);border-radius:6px;font-size:13px">
        <option value="">Tous les statuts</option>
        <option value="ok">Normal</option>
        <option value="warning">Avertissement</option>
        <option value="critical">Critique</option>
        <option value="error">Erreur</option>
    </select>
    <select id="filter-machine" onchange="filterApps()" style="padding:6px 10px;border:1px solid var(--color-border);border-radius:6px;font-size:13px">
        <option value="">Tous les types</option>
        <option value="physical">Physique</option>
        <option value="vm">Virtuelle</option>
        <option value="container">Conteneur</option>
        <option value="cloud">Cloud</option>
    </select>
    <input type="text" id="filter-search" oninput="filterApps()"
           placeholder="Rechercher une application..."
           style="padding:6px 12px;border:1px solid var(--color-border);border-radius:6px;font-size:13px;width:200px">
</div>

{# Grille des applications #}
<div id="apps-grid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:14px">
{% for app in apps %}
{% set snap = metrics[app.id] ?? null %}
<div class="app-card card"
     data-env="{{ app.environment.id }}"
     data-status="{{ snap ? snap.severity.value : 'unknown' }}"
     data-machine="{{ app.machineType.value }}"
     data-name="{{ app.name|lower }}"
     style="border-top:4px solid {{ app.color }}">
    <div class="card-header" style="padding:12px 16px">
        <div style="display:flex;align-items:center;gap:8px;flex:1;min-width:0">
            <span style="width:9px;height:9px;border-radius:50%;flex-shrink:0;
                         background:{{ snap ? (snap.severity.value == 'ok' ? 'var(--color-ok)' : snap.severity.value in ['critical','error'] ? 'var(--color-critical)' : 'var(--color-warn)') : '#9ca3af' }}"></span>
            <div style="flex:1;min-width:0">
                <div style="font-weight:600;font-size:13.5px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">
                    {{ app.name }}
                </div>
                <div class="text-muted text-sm">{{ app.hostAddress }}</div>
            </div>
        </div>
        <div style="display:flex;gap:5px;flex-shrink:0">
            <span class="os-badge badge-{{ app.osType.value }}">{{ app.osType.value|upper|slice(0,4) }}</span>
            {% if snap %}
            <span class="severity-badge severity-{{ snap.severity.value }}" style="font-size:10px">{{ snap.severity.getLabel() }}</span>
            {% endif %}
        </div>
    </div>
    <div class="card-body" style="padding:12px 16px">

        {# Type de machine #}
        <div style="display:flex;align-items:center;gap:6px;margin-bottom:10px;font-size:12px;color:var(--color-text-secondary)">
            <i class="ti ti-{{ app.machineType.getIcon() }}" style="font-size:14px"></i>
            {{ app.machineType.getLabel() }}
            <span style="margin-left:auto;font-size:10.5px;padding:1px 6px;border-radius:8px;
                         background:{{ app.environment.type.getBadgeColor() }}22;
                         color:{{ app.environment.type.getBadgeColor() }}">
                {{ app.environment.slug }}
            </span>
        </div>

        {# Métriques #}
        {% if snap %}
        <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:6px;margin-bottom:10px">
            {% for label, val, crit, warn in [
                ['CPU', snap.cpuPercent, 90, 75],
                ['RAM', snap.memoryPercent, 85, 70],
                ['Disk', snap.maxDiskPercent, 90, 75]
            ] %}
            <div style="text-align:center;padding:6px;background:var(--color-bg-secondary);border-radius:5px">
                <div style="font-size:15px;font-weight:700;
                            color:{{ val is not null and val >= crit ? 'var(--color-critical)' : val is not null and val >= warn ? 'var(--color-warn)' : 'var(--color-ok)' }}">
                    {{ val is not null ? val ~ '%' : '—' }}
                </div>
                <div style="font-size:10px;color:var(--color-text-tertiary)">{{ label }}</div>
            </div>
            {% endfor %}
        </div>

        {# Services #}
        <div style="display:flex;gap:5px;margin-bottom:10px;flex-wrap:wrap">
            <span class="severity-badge {{ snap.tomcatStatus == 'running' ? 'severity-ok' : 'severity-critical' }}" style="font-size:10px">
                Tomcat {{ snap.tomcatStatus == 'running' ? '▲' : '▼' }}
            </span>
            <span class="severity-badge {{ snap.dbStatus == 'running' ? 'severity-ok' : 'severity-critical' }}" style="font-size:10px">
                BDD {{ snap.dbStatus == 'running' ? '▲' : '▼' }}
            </span>
            {% if app.agentToken %}
            <span class="severity-badge {{ app.agentToken.isOnline ? 'severity-ok' : 'severity-warning' }}" style="font-size:10px">
                <i class="ti ti-radio" style="font-size:10px"></i>{{ app.agentToken.isOnline ? 'En ligne' : 'Hors ligne' }}
            </span>
            {% endif %}
            {% if snap.bottlenecks|length > 0 %}
            <span class="severity-badge severity-critical" style="font-size:10px" title="{{ snap.bottlenecks|join(', ')|join(', ') }}">
                <i class="ti ti-alert-triangle"></i>{{ snap.bottlenecks|length }} goulot(s)
            </span>
            {% endif %}
        </div>
        {% else %}
        <div style="text-align:center;padding:16px;color:var(--color-text-tertiary);font-size:12.5px">
            <i class="ti ti-loader" style="display:block;font-size:20px;margin-bottom:4px"></i>
            En attente de données
        </div>
        {% endif %}

        {# Technologies (badges) #}
        {% if app.detectedTechnologies|length > 0 %}
        <div style="display:flex;gap:3px;flex-wrap:wrap">
            {% for tech in app.detectedTechnologies|slice(0,5) %}
            <span title="{{ tech.type|tech_label }}{% if tech.version %} v{{ tech.version }}{% endif %}"
                  style="font-size:10px;padding:2px 5px;background:var(--color-bg-secondary);
                         border:1px solid var(--color-border);border-radius:4px;font-family:monospace">
                {{ tech.type|upper|slice(0,6) }}
            </span>
            {% endfor %}
            {% if app.detectedTechnologies|length > 5 %}
            <span style="font-size:10px;color:var(--color-text-tertiary)">+{{ app.detectedTechnologies|length - 5 }}</span>
            {% endif %}
        </div>
        {% endif %}

    </div>
    <div style="padding:10px 16px;border-top:1px solid var(--color-border);
                display:flex;justify-content:space-between;align-items:center">
        <div style="font-size:11.5px;color:var(--color-text-tertiary)">
            {{ snap ? snap.collectedAt|date('H:i:s') : 'Jamais' }}
        </div>
        <div style="display:flex;gap:5px">
            {% if is_granted('ROLE_SUPERADMIN') %}
            <a href="{{ path('app_application_edit', {id: app.id}) }}" class="btn btn-icon btn-secondary" title="Configurer">
                <i class="ti ti-settings" style="font-size:14px"></i>
            </a>
            {% endif %}
            <a href="{{ path('app_application_show', {id: app.id}) }}" class="btn btn-sm btn-primary">
                <i class="ti ti-eye"></i>Détail
            </a>
        </div>
    </div>
</div>
{% else %}
<div style="grid-column:1/-1;text-align:center;padding:60px;color:var(--color-text-tertiary)">
    <i class="ti ti-stack-2" style="font-size:48px;display:block;margin-bottom:12px;color:var(--color-border)"></i>
    <div style="font-size:18px;margin-bottom:8px">Aucune application supervisée</div>
    <p style="font-size:13px;margin-bottom:16px">
        Installez un agent sur vos serveurs pour commencer la supervision automatique.
    </p>
    {% if is_granted('ROLE_SUPERADMIN') %}
    <a href="{{ path('env_index') }}" class="btn btn-primary">
        <i class="ti ti-key"></i>Générer un token agent
    </a>
    {% endif %}
</div>
{% endfor %}
</div>

{% endblock %}

{% block javascript %}
function filterApps() {
    const envFilter    = document.getElementById('filter-env').value;
    const statusFilter = document.getElementById('filter-status').value;
    const machineFilter= document.getElementById('filter-machine').value;
    const search       = document.getElementById('filter-search').value.toLowerCase();

    document.querySelectorAll('.app-card').forEach(card => {
        const env     = card.dataset.env;
        const status  = card.dataset.status;
        const machine = card.dataset.machine;
        const name    = card.dataset.name;

        let show = true;
        if (envFilter    && env    !== envFilter)             show = false;
        if (statusFilter && status !== statusFilter)          show = false;
        if (machineFilter) {
            if (machineFilter === 'vm' && !machine.startsWith('vm_')) show = false;
            else if (machineFilter === 'cloud' && !machine.startsWith('cloud_')) show = false;
            else if (machineFilter !== 'vm' && machineFilter !== 'cloud' && machine !== machineFilter) show = false;
        }
        if (search && !name.includes(search))                 show = false;

        card.style.display = show ? '' : 'none';
    });
}
{% endblock %}
