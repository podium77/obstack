{% extends "base.html.twig" %}

{% block title %}Paramètres - obstack{% endblock %}

{% block content %}
<div class="container mx-auto px-4 py-8">
    <h1 class="text-3xl font-bold mb-6">Paramètres</h1>
    
    <div class="grid grid-cols-1 gap-6">
        <div class="bg-white border border-gray-300 rounded-lg p-6">
            <h2 class="text-xl font-semibold mb-4">Informations de l'entreprise</h2>
            <p class="text-gray-600 mb-2">
                <strong>Nom:</strong> {{ company.name }}
            </p>
            <p class="text-gray-600 mb-2">
                <strong>Statut:</strong> 
                {% if company.active %}
                    <span class="inline-block bg-green-100 text-green-800 px-2 py-1 rounded text-xs">Actif</span>
                {% else %}
                    <span class="inline-block bg-red-100 text-red-800 px-2 py-1 rounded text-xs">Inactif</span>
                {% endif %}
            </p>
        </div>
        
        <div class="bg-white border border-gray-300 rounded-lg p-6">
            <h2 class="text-xl font-semibold mb-4">Fonctionnalités</h2>
            <ul class="space-y-2 text-gray-600">
                <li>
                    <strong>RCA Activé:</strong>
                    {% if company.rcaEnabled %}
                        <span class="inline-block bg-green-100 text-green-800 px-2 py-1 rounded text-xs">Oui</span>
                    {% else %}
                        <span class="inline-block bg-gray-100 text-gray-800 px-2 py-1 rounded text-xs">Non</span>
                    {% endif %}
                </li>
                <li>
                    <strong>Knowledge Graph Activé:</strong>
                    {% if company.kgEnabled %}
                        <span class="inline-block bg-green-100 text-green-800 px-2 py-1 rounded text-xs">Oui</span>
                    {% else %}
                        <span class="inline-block bg-gray-100 text-gray-800 px-2 py-1 rounded text-xs">Non</span>
                    {% endif %}
                </li>
            </ul>
        </div>
    </div>
</div>
{% endblock %}
