{% extends "base.html.twig" %}

{% block title %}Kubernetes - obstack{% endblock %}

{% block content %}
<div class="container mx-auto px-4 py-8">
    <h1 class="text-3xl font-bold mb-6">Kubernetes</h1>
    
    {% if environments %}
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
            {% for env in environments %}
                <div class="border border-gray-300 rounded-lg p-4 bg-white shadow">
                    <h3 class="text-lg font-semibold mb-2">{{ env.name }}</h3>
                    <p class="text-sm text-gray-600 mb-4">
                        {% if env.kubernetesEnabled %}
                            <span class="inline-block bg-green-100 text-green-800 px-2 py-1 rounded text-xs">Kubernetes activé</span>
                        {% else %}
                            <span class="inline-block bg-gray-100 text-gray-800 px-2 py-1 rounded text-xs">Non configuré</span>
                        {% endif %}
                    </p>
                    {% if env.kubernetesEnabled %}
                        <a href="{{ path('k8s_k8s_dashboard', {id: env.id}) }}" class="inline-block bg-blue-500 text-white px-4 py-2 rounded hover:bg-blue-600 text-sm">
                            Voir le tableau de bord
                        </a>
                    {% endif %}
                </div>
            {% endfor %}
        </div>
    {% else %}
        <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-4">
            <p class="text-yellow-800">Aucun environnement Kubernetes configuré.</p>
        </div>
    {% endif %}
</div>
{% endblock %}
