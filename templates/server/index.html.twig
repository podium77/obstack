{% extends "base.html.twig" %}

{% block title %}Serveurs - obstack{% endblock %}

{% block content %}
<div class="container mx-auto px-4 py-8">
    <h1 class="text-3xl font-bold mb-6">Serveurs</h1>
    
    {% if servers %}
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
            {% for server in servers %}
                <div class="border border-gray-300 rounded-lg p-4 bg-white shadow">
                    <h3 class="text-lg font-semibold mb-2">{{ server.app.name }}</h3>
                    <p class="text-sm text-gray-600 mb-2">
                        <strong>Environnement:</strong> {{ server.environment.name }}
                    </p>
                    <p class="text-sm text-gray-600 mb-2">
                        <strong>Statut:</strong> 
                        {% if server.app.active %}
                            <span class="inline-block bg-green-100 text-green-800 px-2 py-1 rounded text-xs">Actif</span>
                        {% else %}
                            <span class="inline-block bg-red-100 text-red-800 px-2 py-1 rounded text-xs">Inactif</span>
                        {% endif %}
                    </p>
                </div>
            {% endfor %}
        </div>
    {% else %}
        <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-4">
            <p class="text-yellow-800">Aucun serveur trouvé. Enregistrez d'abord des agents.</p>
        </div>
    {% endif %}
</div>
{% endblock %}
